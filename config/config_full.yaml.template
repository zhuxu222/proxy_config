#   standard = 鏍囧噯鍔犺浇锛堝叏閲忓姞杞藉埌鍐呭瓨锛屾煡璇㈠揩浣嗗崰鍐呭瓨锛岀害 50-100MB锛?#   memconservative = 鍐呭瓨鑺傜害妯″紡锛堟寜闇€鍔犺浇锛岀渷鍐呭瓨浣嗛娆℃煡璇㈡參锛?# 璺敱鍣ㄥ唴瀛樺厖瓒筹紙鈮?12MB锛夌敤 standard锛屽唴瀛樼揣寮犵敤 memconservative
geodata-loader: standard

# ---- TCP 骞跺彂杩炴帴 ----
# 鍩熷悕瑙ｆ瀽寰楀埌澶氫釜 IP 鏃讹紝鏄惁鍚屾椂灏濊瘯杩炴帴鎵€鏈?IP
# true  = 骞跺彂杩炴帴鎵€鏈夎В鏋愬埌鐨?IP锛岄€夋嫨鏈€鍏堟垚鍔熺殑锛圚appy Eyeballs 绠楁硶锛?#         浼樼偣锛氬ぇ骞呴檷浣庤繛鎺ュ欢杩燂紝鑷姩閫夋渶浼?IP
#         缂虹偣锛氱煭鏆傚鍔犺繛鎺ユ暟
# false = 鎸夐『搴忛€愪釜灏濊瘯
# 鎺ㄨ崘寮€鍚紝瀵?CDN 鍩熷悕鏁堟灉灏や负鏄庢樉
tcp-concurrent: true

# ---- 缁熶竴寤惰繜璁＄畻 ----
# 鏄惁灏?TLS 鎻℃墜鏃堕棿绾冲叆鑺傜偣寤惰繜娴嬮噺
# true  = 寤惰繜 = TCP 鎻℃墜 + TLS 鎻℃墜 + HTTP 璇锋眰锛堟洿鐪熷疄鍙嶆槧鐢ㄦ埛鎰熺煡鐨勫欢杩燂級
# false = 寤惰繜 = 浠?TCP 鎻℃墜鏃堕棿锛堟暟鍊兼洿浣庝絾涓嶅弽鏄犵湡瀹炰綋楠岋級
# 鎺ㄨ崘寮€鍚紝璁?url-test 鑷姩閫夎妭鐐规椂閫夊嚭鐪熸蹇殑鑺傜偣
unified-delay: true

#----------------------------------------------------------
# 瀹為獙鎬у姛鑳?#----------------------------------------------------------
experimental:
  # 绂佺敤 QUIC 鐨?GSO (Generic Segmentation Offload)
  # 鏈変簺杞矾鐢辩綉鍗￠┍鍔ㄥ GSO 鍏煎涓嶅ソ锛屽彲鑳藉鑷?UDP 涓㈠寘鎴栨柇娴侊紝寤鸿涓?true 绂佺敤
  quic-go-disable-gso: true


#----------------------------------------------------------
# 娴侀噺鍡呮帰 (Sniffer)
# 浠庢祦閲忎腑鎭㈠鐪熷疄鐨勫煙鍚嶃€?# 姣斿 TUN 妯″紡鎴?Fake-IP 妯″紡涓嬶紝搴曞眰鍙兘鍙湁 IP 鏁版嵁锛孋lash 浼氬皾璇曢€氳繃
# 瑙ｆ瀽 TLS SNI 鎴?HTTP Host 瀛楁锛屾妸 IP 杩樺師鍥炵湡瀹炲煙鍚嶏紝绮惧噯鍖归厤鍒嗘祦瑙勫垯
#----------------------------------------------------------
sniffer:
  enable: true
  # 鏄惁鐢ㄥ梾鎺㈠嚭鐨勫煙鍚嶈鐩栧師鐩爣
  override-destination: true
  sniff:
    QUIC:
      ports:
      - 443
    TLS:
      ports:
      - 443
      - 8443
    HTTP:
      ports:
      - 80
      - 8080-8880
      override-destination: true
  
  # ---- 寮哄埗浣跨敤鍡呮帰鐨勫煙鍚?----
  # Netflix/AWS 绛夐儴鍒嗘湇鍔″瓨鍦?CDN IP 娣风敤鎯呭喌
  # 蹇呴』閫氳繃鍩熷悕鎵嶈兘姝ｇ‘瑙ｉ攣锛屾墍浠ュ己鍒舵牴鎹?TLS 鍒嗘祦
  force-domain:
  - "+.netflix.com"
  - "+.nflxvideo.net"
  - "+.amazonaws.com"
  - "+.media.dssott.com"
  
  # ---- 璺宠繃鍡呮帰鐨勫煙鍚?----
  # 璇稿 Mijia銆丄pple Push 绛夌壒娈婂崗璁櫧鐒跺湪 443 绔彛
  # 浣嗕笉鏄爣鍑嗙殑 TLS锛屾垨鑰呭 SNI 鏁忔劅锛屽梾鎺細瀵艰嚧瀹冩柇绾匡紝闇€瑕佺粫杩?  skip-domain:
  - Mijia Cloud
  - dlg.io.mi.com
  - "+.oray.com"
  - "+.sunlogin.net"
  - "+.push.apple.com"
  
  # 寮哄埗杩涜鍙嶅悜 DNS 鏄犲皠
  force-dns-mapping: true
  # 瑙ｆ瀽鍑虹函 IP 璇锋眰骞跺尮閰嶈鍒?  parse-pure-ip: true

#----------------------------------------------------------
# TUN 妯″紡 (铏氭嫙缃戝崱)
# 寮€鍚悗浼氬湪绯荤粺閲屽垱寤轰竴寮犲彨 utun 鐨勭綉鍗★紝鎺ョ绯荤粺鎵€鏈夋祦閲忥紙鍖呮嫭涓嶆敮鎸佽缃唬鐞嗙殑杞欢锛?#----------------------------------------------------------
tun:
  enable: true
  # 鍗忚鏍堬細gvisor / system / mixed銆俿ystem 鎬ц兘鏈€濂?  stack: system
  device: utun
  # DNS 鍔寔閰嶇疆锛屽皢 127.0.0.1:53 鐨?DNS 璇锋眰鍔寔缁?Clash 鐨?DNS 寮曟搸
  dns-hijack:
  - 127.0.0.1:53
  # Endpoint Independent NAT (涓昏閽堝 UDP 绌块€忔父鎴忕瓑) 
  endpoint-independent-nat: true
  # ---- 璺敱閰嶇疆 ----
  # OpenClash 杩欑鐢变笂灞傞槻鐏(iptables/nftables)閰嶅悎鐨勬儏鍐?  # 涓嬮潰涓変釜鏈€濂藉叏鏄?false锛屼互閬垮厤璺敱琛ㄥ啿绐佹寰幆
  auto-route: false
  auto-detect-interface: false
  auto-redirect: false
  strict-route: false

