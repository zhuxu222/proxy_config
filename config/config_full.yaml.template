#----------------------------------------------------------
# 代理节点
#----------------------------------------------------------
proxies:
- name: nube_1
  type: vless
  server: <PROXY_SERVER>
  port: 13002
  uuid: <PROXY_UUID>
  udp: true
  xudp: true
  skip-cert-verify: false
  tls: true
  client-fingerprint: chrome
  servername: <REALITY_SNI>
  network: tcp
  reality-opts:
    public-key: <REALITY_PUBLIC_KEY>
    short-id: "<REALITY_SHORT_ID>"
  ip-version: ipv4-prefer
  tfo: false

#----------------------------------------------------------
# 代理组
#----------------------------------------------------------
proxy-groups:

# 核心路由组
- name: Auto - UrlTest
  type: url-test
  proxies:
  - nube_1
  url: http://cp.cloudflare.com/generate_204
  interval: 600
  tolerance: 150

- name: Proxy
  type: select
  proxies:
  - Auto - UrlTest
  - DIRECT
  - nube_1

- name: Domestic
  type: select
  proxies:
  - DIRECT
  - Proxy

- name: Others
  type: select
  proxies:
  - Proxy
  - DIRECT
  - Domestic

# 科技服务
- name: Microsoft
  type: select
  proxies:
  - Proxy
  - DIRECT

