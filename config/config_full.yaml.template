#----------------------------------------------------------
# 分流规则 (Rules)
# 配置路由匹配算法，按自上至下优先级逐条匹配。
# 当一个请求过来，如果在上面规则里命中，就会立刻抛给该策略组，不继续往下找。
#
# 常用的匹配模式：
#   DOMAIN,             # 完整域名匹配
#   DOMAIN-SUFFIX,      # 域名后缀匹配 (如匹配 baidu.com 及其所有子域名)
#   DOMAIN-KEYWORD,     # 域名包含某个关键字
#   GEOIP,              # 根据连接的目的IP，判断所属国家
#   RULE-SET,           # 匹配 `rule-providers` 节点里的规则集，最常用
#   PROCESS-NAME,       # 根据底层发起流量的进程名字分流（如 aria2c）
#   MATCH,              # 兜底规则，所有都没命中最后走这条
#----------------------------------------------------------
rules:

# 特殊规则：BT/PT  Tracker 目录直连防止走代理被删号
- GEOSITE,category-public-tracker,DIRECT

# 自定义规则集（最高优先级）
- RULE-SET,Lenovo,Lenovo-Rules
- RULE-SET,Docker,Docker
- RULE-SET,AI Custom,AI Suite

# 拦截类
- RULE-SET,AdBlock,AdBlock
- RULE-SET,HTTPDNS,HTTPDNS

# 特殊直连
