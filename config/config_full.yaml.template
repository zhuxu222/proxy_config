#----------------------------------------------------------
# DNS 配置
#----------------------------------------------------------
dns:
  enable: true
  ipv6: true
  enhanced-mode: redir-host
  listen: 0.0.0.0:7874
  respect-rules: true
  nameserver:
  - 119.29.29.29
  - 119.28.28.28
  - 223.5.5.5
  - https://doh.pub/dns-query
  - https://dns.alidns.com/dns-query
  fallback:
  - https://dns.google/dns-query
  - https://dns.cloudflare.com/dns-query
  default-nameserver:
  - 114.114.114.114
  - 119.29.29.29
  - 223.5.5.5
  proxy-server-nameserver:
  - 114.114.114.114
  - 119.29.29.29
  - 8.8.8.8
  - 1.1.1.1

#----------------------------------------------------------
# 端口配置
#----------------------------------------------------------
redir-port: 7892
tproxy-port: 7895
port: 7890
socks-port: 7891
mixed-port: 7893

#----------------------------------------------------------
# 通用设置
#----------------------------------------------------------
mode: rule
allow-lan: true
external-controller: 0.0.0.0:9090
secret: <API_SECRET>
bind-address: "*"
external-ui: "/usr/share/openclash/ui"
external-ui-name: metacubexd
external-ui-url: https://codeload.github.com/MetaCubeX/metacubexd/zip/refs/heads/gh-pages
keep-alive-interval: 15
keep-alive-idle: 600
ipv6: true
geodata-mode: true
geodata-loader: standard
tcp-concurrent: true
unified-delay: true

#----------------------------------------------------------
# 实验性功能
#----------------------------------------------------------
experimental:
  quic-go-disable-gso: true

#----------------------------------------------------------
# GeoData 数据源
#----------------------------------------------------------
geox-url:
  mmdb: https://testingcf.jsdelivr.net/gh/alecthw/mmdb_china_ip_list@release/lite/Country.mmdb
  geoip: https://testingcf.jsdelivr.net/gh/Loyalsoldier/v2ray-rules-dat@release/geoip.dat
  geosite: https://testingcf.jsdelivr.net/gh/Loyalsoldier/v2ray-rules-dat@release/geosite.dat
  asn: https://testingcf.jsdelivr.net/gh/xishang0128/geoip@release/GeoLite2-ASN.mmdb

#----------------------------------------------------------
# 流量嗅探
#----------------------------------------------------------
sniffer:
  enable: true
  override-destination: true
  sniff:
    QUIC:
      ports:
      - 443
    TLS:
      ports:
      - 443
      - 8443
    HTTP:
      ports:
      - 80
      - 8080-8880
      override-destination: true
  force-domain:
  - "+.netflix.com"
  - "+.nflxvideo.net"
  - "+.amazonaws.com"
  - "+.media.dssott.com"
  skip-domain:
  - Mijia Cloud
  - dlg.io.mi.com
  - "+.oray.com"
  - "+.sunlogin.net"
  - "+.push.apple.com"
  force-dns-mapping: true
  parse-pure-ip: true

#----------------------------------------------------------
# TUN 模式
#----------------------------------------------------------
tun:
  enable: true
  stack: system
  device: utun
  dns-hijack:
  - 127.0.0.1:53
  endpoint-independent-nat: true
  auto-route: false
  auto-detect-interface: false
  auto-redirect: false
  strict-route: false

#----------------------------------------------------------
# 配置持久化
#----------------------------------------------------------
profile:
  store-selected: true

#----------------------------------------------------------
# NTP 时间同步
#----------------------------------------------------------
ntp:
  enable: true
  server: time.apple.com
  port: 123
  interval: 30
  write-to-system: true

#----------------------------------------------------------
# 代理认证
#----------------------------------------------------------
authentication:
- Clash:<AUTH_PASSWORD>

