    type: http
    behavior: classical
    url: https://fastly.jsdelivr.net/gh/zhuxu222/proxy_config@main/rule_provider/custom/Lenovo.yaml
    path: "./rule_provider/Lenovo"
    interval: 86400

  # ====== 上游规则集 (upstream/) ======

