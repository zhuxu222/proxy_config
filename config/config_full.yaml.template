#==========================================================
# Clash Meta (mihomo) 完整配置
# 所有规则集统一从 zhuxu222/proxy_config 仓库加载
#==========================================================

#----------------------------------------------------------
# 代理节点 (Proxies)
# 定义所有用于科学上网的实际服务器节点
#----------------------------------------------------------
proxies:
  # 这是一个 VLESS + REALITY 的节点配置
- name: nube_1
  type: vless
  # 服务器 IP 或域名
  server: <PROXY_SERVER>
  # 代理端口
  port: 13002
  # 用户识别码
  uuid: <PROXY_UUID>
  # 开启 UDP 支持 (玩游戏、看视频、QUIC必备)
  udp: true
  # 开启 XUDP (更高级的 UDP 转发，提升稳定性)
  xudp: true
  # 是否跳过证书严重 (为了安全建议 false)
  skip-cert-verify: false
  # 开启 TLS 加密
  tls: true
  # TLS 指纹模拟，伪装成 Chrome 浏览器流量特征
  client-fingerprint: chrome
  # SNI (Server Name Indication)，REALITY 用于伪装的目标域名
  servername: <REALITY_SNI>
  # 底层传输协议
  network: tcp
  reality-opts:
    # REALITY 公钥
    public-key: <REALITY_PUBLIC_KEY>
    # REALITY 短 ID
    short-id: "<REALITY_SHORT_ID>"
  # 优先通过 IPv4 连接该节点
  ip-version: ipv4-prefer
  # 是否开启 TCP Fast Open (可能导致某些网络环境下断流，默认关)
  tfo: false

# 企业内网 VPN 透明代理中继节点
- name: Lenovo-VPN
  type: http
  # 通过 DDNS 动态绑定的域名，实现 PVE 内部网关与跳板机解耦
  server: lenovo-inner-proxy.office.zzxh.top
  port: 8080

#----------------------------------------------------------
# 代理组 (Proxy Groups)
# 用于实现自动测速、主备切换、手动选择和策略分流的逻辑组
# 支持四种主要类型：
#   - select:   手动选择节点（最常用）
#   - url-test: 自动并发测速并选择延迟最低的节点
#   - fallback: 按照顺序优先级选择可用的节点（主备容灾）
#   - load-balance: 负载均衡机制
#----------------------------------------------------------
proxy-groups:

# ---- 核心路由组 ----

# 企业内网专线组
- name: Lenovo-Rules
  type: select
  proxies:
  - Lenovo-VPN
  - DIRECT
  - Proxy

# 自动测速组 (UrlTest)
# 每 600 秒测速一次，延迟波动在 150ms 以内不随意切换节点
- name: Auto - UrlTest
  type: url-test
  proxies:
  - nube_1
  # 测速目标网址，通常使用 204 HTTP 状态码的极速服务
  url: http://cp.cloudflare.com/generate_204
  interval: 600
  tolerance: 150

# 全局出墙代理组 (Proxy)
# 绝大多数海外流量的归宿地，默认可以在 自动测速 / 直连 / 手动节点 中做出选择
- name: Proxy
  type: select
  proxies:
  - Auto - UrlTest
  - DIRECT
  - nube_1

# 国内流量组 (Domestic)
# 国内默认走 DIRECT (直连)，当国内服务被墙时可以手动切到代理
- name: Domestic
  type: select
  proxies:
  - DIRECT
  - Proxy

# 其他/漏网之鱼组 (Others)
# 当流量没有匹配到任何规则时的最终去处，通常为了防止 IP 泄露，默认全部走代理
- name: Others
  type: select
  proxies:
  - Proxy
  - DIRECT
  - Domestic

